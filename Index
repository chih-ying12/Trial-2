<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Lost and Found</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Courier Prime', 'Courier New', monospace;
            background-color: #1a1a1a;
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Navigation */
        .navbar {
            background-color: #2d2d2d;
            padding: 15px 30px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #4a4a4a;
            flex-wrap: wrap;
            gap: 15px;
        }

        .logo {
            font-size: 20px;
            font-weight: bold;
            color: #e0e0e0;
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 15px;
            align-items: center;
            flex-wrap: wrap;
        }

        .user-info {
            color: #a0d0a0;
            font-size: 14px;
        }

        .nav-btn {
            background-color: #3a3a3a;
            color: #e0e0e0;
            border: 1px solid #5a5a5a;
            padding: 8px 16px;
            cursor: pointer;
            font-size: 14px;
            font-family: 'Courier Prime', monospace;
        }

        .nav-btn:hover {
            background-color: #4a4a4a;
            border-color: #7a7a7a;
        }

        /* Buttons */
        button, .btn-primary, .btn-secondary, .btn-danger {
            background-color: #3a3a3a;
            color: #e0e0e0;
            border: 1px solid #5a5a5a;
            padding: 10px 20px;
            cursor: pointer;
            font-size: 14px;
            font-family: 'Courier Prime', monospace;
            transition: all 0.3s;
        }

        button:hover, .btn-primary:hover, .btn-secondary:hover, .btn-danger:hover {
            background-color: #4a4a4a;
            border-color: #7a7a7a;
        }

        .btn-primary {
            background-color: #3a5a3a;
            border-color: #5a7a5a;
        }

        .btn-primary:hover {
            background-color: #4a6a4a;
        }

        .btn-secondary {
            background-color: #2a2a4a;
            border-color: #3a3a6a;
        }

        .btn-secondary:hover {
            background-color: #3a3a5a;
        }

        .btn-danger {
            background-color: #5a2a2a;
            border-color: #7a3a3a;
        }

        .btn-danger:hover {
            background-color: #6a3a3a;
        }

        /* Forms */
        .form-container {
            background-color: #2d2d2d;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid #4a4a4a;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: normal;
            color: #c0c0c0;
            font-family: 'Courier Prime', monospace;
        }

        input, textarea, select {
            width: 100%;
            padding: 12px;
            background-color: #1a1a1a;
            border: 1px solid #4a4a4a;
            font-size: 14px;
            font-family: 'Courier Prime', monospace;
            color: #e0e0e0;
        }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #7a7a7a;
        }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        small {
            display: block;
            margin-top: 5px;
            color: #888888;
            font-size: 11px;
        }

        /* Tabs */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
            background-color: #2d2d2d;
            padding: 10px;
            border: 1px solid #4a4a4a;
        }

        .tab {
            padding: 10px 24px;
            background: none;
            color: #b0b0b0;
            border: 1px solid #4a4a4a;
            cursor: pointer;
            font-size: 14px;
            font-family: 'Courier Prime', monospace;
            flex: 1;
        }

        .tab:hover {
            background-color: #3a3a3a;
            color: #ffffff;
        }

        .tab.active {
            background-color: #4a4a4a;
            color: #ffffff;
            border-color: #666666;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.3s;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Cards Grid */
        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .item-card {
            background-color: #2d2d2d;
            overflow: hidden;
            border: 1px solid #4a4a4a;
            transition: border-color 0.3s;
        }

        .item-card:hover {
            border-color: #6a6a6a;
        }

        .item-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background-color: #1a1a1a;
        }

        .item-card-content {
            padding: 20px;
        }

        .item-card h3 {
            margin-bottom: 10px;
            color: #e0e0e0;
            font-size: 18px;
        }

        .item-card p {
            color: #b0b0b0;
            margin-bottom: 8px;
            font-size: 13px;
            line-height: 1.5;
        }

        .item-card .label {
            color: #808080;
            font-weight: bold;
        }

        /* Badges */
        .badge {
            display: inline-block;
            padding: 4px 12px;
            font-size: 11px;
            margin-top: 10px;
        }

        .badge-open {
            background-color: #2a5a2a;
            color: #a0d0a0;
            border: 1px solid #3a7a3a;
        }

        .badge-approved {
            background-color: #2a5a2a;
            color: #a0d0a0;
            border: 1px solid #3a7a3a;
        }

        .badge-rejected {
            background-color: #5a2a2a;
            color: #d0a0a0;
            border: 1px solid #7a3a3a;
        }

        .badge-pending {
            background-color: #5a4a2a;
            color: #d0c0a0;
            border: 1px solid #7a6a3a;
        }

        /* Search */
        .search-bar {
            margin-bottom: 20px;
        }

        .search-input-group {
            display: flex;
            gap: 10px;
        }

        .search-input {
            flex: 1;
        }

        .filter-row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .filter-group {
            flex: 1;
            min-width: 150px;
        }

        .filter-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background-color: #2d2d2d;
            padding: 30px;
            max-width: 550px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            border: 1px solid #5a5a5a;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #4a4a4a;
        }

        .modal-header h3 {
            color: #e0e0e0;
        }

        .close {
            cursor: pointer;
            font-size: 28px;
            color: #b0b0b0;
            transition: color 0.3s;
        }

        .close:hover {
            color: #ffffff;
        }

        /* Question Card */
        .question-card {
            background-color: #3a3a3a;
            padding: 15px;
            margin-bottom: 15px;
            border: 1px solid #5a5a5a;
        }

        .question-card label {
            display: block;
            margin-bottom: 10px;
            color: #d0d0d0;
            font-weight: bold;
        }

        .question-card textarea {
            width: 100%;
            padding: 10px;
            background-color: #1a1a1a;
            border: 1px solid #4a4a4a;
            font-family: 'Courier Prime', monospace;
            color: #e0e0e0;
        }

        /* Item Summary */
        .item-summary {
            background-color: #1a3a1a;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #3a7a3a;
        }

        .item-summary h4 {
            color: #a0d0a0;
            margin-bottom: 10px;
        }

        .item-summary p {
            color: #c0c0c0;
            font-size: 13px;
        }

        /* Modal Buttons */
        .modal-buttons {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #4a4a4a;
        }

        /* Loading */
        .loading {
            text-align: center;
            padding: 40px;
            color: #b0b0b0;
            font-size: 14px;
        }

        /* Hidden */
        .hidden {
            display: none;
        }

        /* Headers */
        h2 {
            color: #e0e0e0;
            margin-bottom: 20px;
            font-weight: normal;
            letter-spacing: 1px;
        }

        /* Alert */
        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border-left: 3px solid;
            animation: slideIn 0.3s;
        }

        .alert-success {
            background-color: #1a3a1a;
            color: #a0d0a0;
            border-left-color: #2a7a2a;
        }

        .alert-error {
            background-color: #3a1a1a;
            color: #d0a0a0;
            border-left-color: #7a2a2a;
        }

        @keyframes slideIn {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        /* Logout Page Styles */
        .logout-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 70vh;
        }

        .logout-icon {
            margin-bottom: 30px;
        }

        .checkmark {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background-color: #2a5a2a;
            border: 2px solid #4a8a4a;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            font-size: 48px;
            color: #a0d0a0;
            animation: fadeInScale 0.5s ease-out;
        }

        @keyframes fadeInScale {
            from { opacity: 0; transform: scale(0.5); }
            to { opacity: 1; transform: scale(1); }
        }

        .logout-message {
            color: #b0b0b0;
            margin: 20px 0;
            line-height: 1.6;
            font-size: 14px;
        }

        .logout-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin: 30px 0 20px;
            flex-wrap: wrap;
        }

        .logout-buttons a {
            text-decoration: none;
            padding: 12px 24px;
            font-family: 'Courier Prime', monospace;
            font-size: 14px;
            cursor: pointer;
            display: inline-block;
        }

        .redirect-note {
            color: #808080;
            font-size: 12px;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #4a4a4a;
        }

        #countdown {
            font-weight: bold;
            color: #d0c0a0;
            font-size: 16px;
        }

        /* Verification fields */
        .verification-fields {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #4a4a4a;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 10px;
            }
            
            .navbar {
                flex-direction: column;
                text-align: center;
            }
            
            .items-grid {
                grid-template-columns: 1fr;
            }
            
            .tabs {
                flex-direction: column;
            }
            
            .tab {
                width: 100%;
                text-align: center;
            }
            
            .search-input-group {
                flex-direction: column;
            }
            
            .filter-row {
                flex-direction: column;
            }
            
            .modal-buttons {
                flex-direction: column;
            }
            
            .modal-buttons button {
                width: 100%;
            }
            
            .logout-buttons {
                flex-direction: column;
            }
            
            .logout-buttons a {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <div id="app">
        <!-- Login/Register View -->
        <div id="authView">
            <div class="container">
                <nav class="navbar">
                    <div class="logo">Secure Lost and Found</div>
                </nav>

                <div class="form-container" style="max-width: 450px; margin: 0 auto;">
                    <h2 style="margin-bottom: 20px; text-align: center;">Welcome</h2>
                    
                    <div class="tabs" style="justify-content: center;">
                        <button class="tab active" onclick="switchAuthTab('login')">Login</button>
                        <button class="tab" onclick="switchAuthTab('register')">Register</button>
                    </div>
                    
                    <div id="loginForm" class="tab-content active">
                        <form onsubmit="login(event); return false;">
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" id="loginUsername" required placeholder="Enter your username">
                            </div>
                            <div class="form-group">
                                <label>Password</label>
                                <input type="password" id="loginPassword" required placeholder="Enter your password">
                            </div>
                            <button type="submit" style="width: 100%;">Login</button>
                        </form>
                        <p style="margin-top: 15px; text-align: center; font-size: 11px; color: #888888;">
                            Demo account: demo / user123
                        </p>
                    </div>
                    
                    <div id="registerForm" class="tab-content">
                        <form onsubmit="register(event); return false;">
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" id="regUsername" required placeholder="Choose a username">
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" id="regEmail" required placeholder="your@email.com">
                            </div>
                            <div class="form-group">
                                <label>Password</label>
                                <input type="password" id="regPassword" required placeholder="Choose a password (min 4 characters)">
                            </div>
                            <button type="submit" style="width: 100%;">Register</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dashboard View (shown after login) -->
        <div id="dashboardView" class="hidden">
            <div class="container">
                <nav class="navbar">
                    <div class="logo">Secure Lost and Found</div>
                    <div class="nav-links">
                        <span class="user-info" id="userInfo"></span>
                        <button class="nav-btn" onclick="showLogoutPage()">Logout</button>
                    </div>
                </nav>

                <div class="tabs">
                    <button class="tab active" onclick="switchDashboardTab('browse')">Browse Found Items</button>
                    <button class="tab" onclick="switchDashboardTab('report')">Report Found Item</button>
                    <button class="tab" onclick="switchDashboardTab('myClaims')">My Claims</button>
                </div>

                <!-- Browse Found Items Tab -->
                <div id="browseTab" class="tab-content active">
                    <div class="form-container">
                        <h2>Search for Your Lost Item</h2>
                        <div class="search-bar">
                            <div class="form-group">
                                <label>Search by keyword</label>
                                <div class="search-input-group">
                                    <input type="text" id="searchKeyword" placeholder="Enter keywords like: black backpack, silver ipad..." class="search-input">
                                    <button onclick="performSearch()" class="btn-primary">Search</button>
                                    <button onclick="clearSearch()" class="btn-secondary">Clear</button>
                                </div>
                            </div>
                        </div>
                        <div class="filter-row">
                            <div class="filter-group">
                                <label>Filter by Color</label>
                                <select id="filterColor">
                                    <option value="">All Colors</option>
                                    <option value="black">Black</option>
                                    <option value="white">White</option>
                                    <option value="red">Red</option>
                                    <option value="blue">Blue</option>
                                    <option value="green">Green</option>
                                    <option value="brown">Brown</option>
                                    <option value="gray">Gray</option>
                                    <option value="silver">Silver</option>
                                </select>
                            </div>
                            <div class="filter-group">
                                <label>Filter by Type</label>
                                <select id="filterType">
                                    <option value="">All Types</option>
                                    <option value="electronic">Electronic</option>
                                    <option value="money">Money Related</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="filter-buttons">
                            <button onclick="applyFilters()" class="btn-primary">Apply Filters</button>
                            <button onclick="clearFilters()" class="btn-secondary">Clear Filters</button>
                        </div>
                    </div>
                    <div id="searchResults" class="items-grid">
                        <div class="loading">Loading found items...</div>
                    </div>
                </div>

                <!-- Report Found Item Tab -->
                <div id="reportTab" class="tab-content">
                    <div class="form-container">
                        <h2>Report a Found Item</h2>
                        <form id="foundItemForm" onsubmit="reportFoundItem(event); return false;">
                            <div class="form-group">
                                <label>Item Type *</label>
                                <select id="itemType" required onchange="toggleVerificationFields()">
                                    <option value="">Select type</option>
                                    <option value="electronic">Electronic</option>
                                    <option value="money">Money Related</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label>Title / Item Name *</label>
                                <input type="text" id="itemTitle" required placeholder="e.g., Black Backpack, Silver iPad">
                            </div>
                            
                            <div class="form-group">
                                <label>Color *</label>
                                <input type="text" id="itemColor" required placeholder="e.g., Black, Red, Blue">
                            </div>
                            
                            <div class="form-group">
                                <label>Brand / Model</label>
                                <input type="text" id="itemBrand" placeholder="e.g., Apple, Nike, Samsung">
                            </div>
                            
                            <div class="form-group">
                                <label>Description (public) *</label>
                                <textarea id="publicDescription" required placeholder="Describe what the item looks like from the outside..."></textarea>
                            </div>
                            
                            <div class="form-group">
                                <label>Location Found *</label>
                                <input type="text" id="foundLocation" required placeholder="e.g., Central Park, Bus Station">
                            </div>
                            
                            <div class="form-group">
                                <label>Date Found *</label>
                                <input type="date" id="foundDate" required>
                            </div>
                            
                            <div class="form-group">
                                <label>Time Found *</label>
                                <input type="time" id="foundTime" required>
                            </div>
                            
                            <div id="electronicFields" class="hidden verification-fields">
                                <div class="form-group">
                                    <label style="color: #d0a060;">Verification: Wallpaper / Lock Screen Description *</label>
                                    <textarea id="wallpaperDescription" placeholder="Describe the wallpaper, lock screen image, or background of the device..."></textarea>
                                    <small>Used to verify the real owner. Not shown publicly.</small>
                                </div>
                                <div class="form-group">
                                    <label style="color: #d0a060;">Verification: Device Passcode / Pattern</label>
                                    <input type="text" id="devicePasscode" placeholder="Only if owner wants to verify this way">
                                    <small>Used to verify the real owner. Not shown publicly.</small>
                                </div>
                            </div>
                            
                            <div id="moneyFields" class="hidden verification-fields">
                                <div class="form-group">
                                    <label style="color: #d0a060;">Verification: Exact Amount of Money *</label>
                                    <input type="number" id="moneyAmount" step="0.01" placeholder="Enter the exact amount">
                                    <small>Used to verify the real owner. Not shown publicly.</small>
                                </div>
                                <div class="form-group">
                                    <label style="color: #d0a060;">Verification: Currency Type</label>
                                    <select id="currencyType">
                                        <option value="">Select currency</option>
                                        <option value="USD">USD - US Dollar</option>
                                        <option value="EUR">EUR - Euro</option>
                                        <option value="GBP">GBP - British Pound</option>
                                        <option value="JPY">JPY - Japanese Yen</option>
                                        <option value="CAD">CAD - Canadian Dollar</option>
                                        <option value="AUD">AUD - Australian Dollar</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div id="otherFields" class="hidden verification-fields">
                                <div class="form-group">
                                    <label style="color: #d0a060;">Verification: Unique Identifying Feature *</label>
                                    <textarea id="uniqueFeature" placeholder="Example: Small scratch on back, custom engraving, specific sticker..."></textarea>
                                    <small>Used to verify the real owner. Not shown publicly.</small>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label>Public Photo URL (optional)</label>
                                <input type="text" id="photoUrl" placeholder="Enter image URL or leave empty">
                                <small>Paste a direct image link from the web</small>
                            </div>
                            
                            <button type="submit">Submit Found Report</button>
                        </form>
                    </div>
                </div>

                <!-- My Claims Tab -->
                <div id="myClaimsTab" class="tab-content">
                    <h2>My Claims</h2>
                    <div id="myClaimsList" class="items-grid">
                        <div class="loading">Loading your claims...</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Logout Page View -->
        <div id="logoutView" class="hidden">
            <div class="container">
                <nav class="navbar">
                    <div class="logo">Secure Lost and Found</div>
                </nav>

                <div class="logout-container">
                    <div class="form-container" style="max-width: 500px; margin: 0 auto; text-align: center;">
                        <div class="logout-icon">
                            <div class="checkmark">✓</div>
                        </div>
                        
                        <h2>Successfully Logged Out</h2>
                        
                        <p class="logout-message">
                            You have been securely logged out of your account.
                            <br>
                            Your session has been terminated.
                        </p>
                        
                        <div class="logout-buttons">
                            <button onclick="showAuthView()" class="btn-primary">Login Again</button>
                            <button onclick="showAuthView()" class="btn-secondary">Return to Home</button>
                        </div>
                        
                        <p class="redirect-note">
                            Redirecting to login page in <span id="logoutCountdown">5</span> seconds.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Verification Modal -->
    <div id="verificationModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Verify Ownership</h3>
                <span class="close" onclick="closeVerificationModal()">&times;</span>
            </div>
            <div id="verificationModalBody"></div>
        </div>
    </div>

    <script>
        // ========== GLOBAL VARIABLES ==========
        let currentUser = null;
        let allFoundItems = [];
        let currentClaimItem = null;

        // ========== INITIALIZATION ==========
        function loadData() {
            // Load users from localStorage
            if (!localStorage.getItem('users')) {
                const defaultUsers = [
                    { id: 1, username: 'demo', email: 'demo@example.com', password: 'user123', role: 'user' }
                ];
                localStorage.setItem('users', JSON.stringify(defaultUsers));
            }
            
            // Load found items from localStorage
            if (!localStorage.getItem('foundItems')) {
                localStorage.setItem('foundItems', JSON.stringify([]));
            }
            
            // Load claims from localStorage
            if (!localStorage.getItem('claims')) {
                localStorage.setItem('claims', JSON.stringify([]));
            }
            
            allFoundItems = JSON.parse(localStorage.getItem('foundItems'));
            
            // Check if user is logged in
            const savedUser = localStorage.getItem('currentUser');
            if (savedUser) {
                currentUser = JSON.parse(savedUser);
                showDashboardView();
                loadFoundItems();
                loadMyClaims();
            } else {
                showAuthView();
            }
        }

        // ========== VIEW MANAGEMENT ==========
        function showAuthView() {
            document.getElementById('authView').classList.remove('hidden');
            document.getElementById('dashboardView').classList.add('hidden');
            document.getElementById('logoutView').classList.add('hidden');
            currentUser = null;
            localStorage.removeItem('currentUser');
            
            // Clear countdown if exists
            if (window.logoutInterval) clearInterval(window.logoutInterval);
        }

        function showDashboardView() {
            document.getElementById('authView').classList.add('hidden');
            document.getElementById('dashboardView').classList.remove('hidden');
            document.getElementById('logoutView').classList.add('hidden');
            document.getElementById('userInfo').innerHTML = `Welcome, ${currentUser.username}`;
            loadFoundItems();
            loadMyClaims();
        }

        function showLogoutPage() {
            document.getElementById('authView').classList.add('hidden');
            document.getElementById('dashboardView').classList.add('hidden');
            document.getElementById('logoutView').classList.remove('hidden');
            
            localStorage.removeItem('currentUser');
            currentUser = null;
            
            // Start countdown
            let seconds = 5;
            const countdownElement = document.getElementById('logoutCountdown');
            
            if (window.logoutInterval) clearInterval(window.logoutInterval);
            window.logoutInterval = setInterval(() => {
                seconds--;
                if (countdownElement) countdownElement.textContent = seconds;
                if (seconds <= 0) {
                    clearInterval(window.logoutInterval);
                    showAuthView();
                }
            }, 1000);
        }

        // ========== AUTHENTICATION ==========
        function switchAuthTab(tab) {
            const tabs = document.querySelectorAll('#authView .tab');
            const contents = document.querySelectorAll('#authView .tab-content');
            
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));
            
            if (tab === 'login') {
                tabs[0].classList.add('active');
                document.getElementById('loginForm').classList.add('active');
            } else {
                tabs[1].classList.add('active');
                document.getElementById('registerForm').classList.add('active');
            }
        }

        function login(event) {
            event.preventDefault();
            
            const username = document.getElementById('loginUsername').value;
            const password = document.getElementById('loginPassword').value;
            
            const users = JSON.parse(localStorage.getItem('users'));
            const user = users.find(u => u.username === username && u.password === password);
            
            if (user) {
                currentUser = user;
                localStorage.setItem('currentUser', JSON.stringify(user));
                showAlert('Login successful!', 'success');
                showDashboardView();
            } else {
                showAlert('Invalid username or password', 'error');
            }
        }

        function register(event) {
            event.preventDefault();
            
            const username = document.getElementById('regUsername').value;
            const email = document.getElementById('regEmail').value;
            const password = document.getElementById('regPassword').value;
            
            if (password.length < 4) {
                showAlert('Password must be at least 4 characters', 'error');
                return;
            }
            
            const users = JSON.parse(localStorage.getItem('users'));
            
            if (users.find(u => u.username === username)) {
                showAlert('Username already exists', 'error');
                return;
            }
            
            const newUser = {
                id: users.length + 1,
                username: username,
                email: email,
                password: password,
                role: 'user'
            };
            
            users.push(newUser);
            localStorage.setItem('users', JSON.stringify(users));
            
            showAlert('Registration successful! Please login.', 'success');
            switchAuthTab('login');
            
            document.getElementById('regUsername').value = '';
            document.getElementById('regEmail').value = '';
            document.getElementById('regPassword').value = '';
        }

        function showAlert(message, type) {
            const container = document.getElementById('authView');
            const existingAlerts = container.querySelectorAll('.alert');
            existingAlerts.forEach(alert => alert.remove());
            
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type}`;
            alertDiv.innerHTML = message;
            container.insertBefore(alertDiv, container.querySelector('.form-container'));
            
            setTimeout(() => alertDiv.remove(), 3000);
        }

        // ========== DASHBOARD FUNCTIONS ==========
        function switchDashboardTab(tabName) {
            const tabs = document.querySelectorAll('#dashboardView .tab');
            const contents = document.querySelectorAll('#dashboardView .tab-content');
            
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(`${tabName}Tab`).classList.add('active');
            
            if (tabName === 'browse') loadFoundItems();
            if (tabName === 'myClaims') loadMyClaims();
        }

        function loadFoundItems() {
            allFoundItems = JSON.parse(localStorage.getItem('foundItems'));
            displayFoundItems(allFoundItems);
        }

