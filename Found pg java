// Global variables
let currentUser = null;
let allFoundItems = [];
let currentClaimItem = null;

// ========== INITIALIZATION ==========
document.addEventListener('DOMContentLoaded', () => {
    checkAuth();
    loadFoundItems();
});

async function checkAuth() {
    try {
        const response = await fetch('/api/me');
        currentUser = await response.json();
        
        if (!currentUser) {
            window.location.href = 'index.html';
            return;
        }
        
        const userInfo = document.getElementById('userInfo');
        if (userInfo) {
            userInfo.innerHTML = `Logged in as: ${currentUser.username}`;
        }
    } catch (error) {
        console.error('Auth check failed:', error);
        window.location.href = 'index.html';
    }
}

async function logout() {
    await fetch('/api/logout', { method: 'POST' });
    window.location.href = 'index.html';
}

// ========== LOAD FOUND ITEMS ==========
async function loadFoundItems() {
    try {
        const response = await fetch('/api/found-items');
        allFoundItems = await response.json();
        displayFoundItems(allFoundItems);
        updateSearchStats(allFoundItems.length, allFoundItems.length);
    } catch (error) {
        console.error('Error loading items:', error);
        const container = document.getElementById('searchResults');
        if (container) {
            container.innerHTML = '<div class="loading">Error loading items. Make sure server is running.</div>';
        }
    }
}

// ========== SEARCH FUNCTIONS ==========
function performSearch() {
    const keyword = document.getElementById('searchKeyword').value.toLowerCase();
    
    if (!keyword) {
        displayFoundItems(allFoundItems);
        updateSearchStats(allFoundItems.length, allFoundItems.length);
        return;
    }
    
    const filtered = allFoundItems.filter(item => {
        return (item.title && item.title.toLowerCase().includes(keyword)) ||
               (item.public_description && item.public_description.toLowerCase().includes(keyword)) ||
               (item.brand && item.brand.toLowerCase().includes(keyword)) ||
               (item.color && item.color.toLowerCase().includes(keyword)) ||
               (item.location && item.location.toLowerCase().includes(keyword));
    });
    
    displayFoundItems(filtered);
    updateSearchStats(filtered.length, allFoundItems.length);
}

function clearSearch() {
    document.getElementById('searchKeyword').value = '';
    displayFoundItems(allFoundItems);
    updateSearchStats(allFoundItems.length, allFoundItems.length);
}

// ========== ADVANCED FILTERS ==========
function toggleAdvancedFilters() {
    const filterContent = document.getElementById('advancedFilters');
    const toggleBtn = document.querySelector('.filter-toggle-btn');
    
    if (filterContent.classList.contains('hidden')) {
        filterContent.classList.remove('hidden');
        toggleBtn.innerHTML = 'Advanced Filters ▲';
    } else {
        filterContent.classList.add('hidden');
        toggleBtn.innerHTML = 'Advanced Filters ▼';
    }
}

function applyAdvancedFilters() {
    const color = document.getElementById('filterColor').value.toLowerCase();
    const type = document.getElementById('filterType').value;
    const brand = document.getElementById('filterBrand').value.toLowerCase();
    const location = document.getElementById('filterLocation').value.toLowerCase();
    const dateRange = document.getElementById('filterDate').value;
    
    let filtered = [...allFoundItems];
    
    if (color) {
        filtered = filtered.filter(item => 
            item.color && item.color.toLowerCase() === color
        );
    }
    
    if (type) {
        filtered = filtered.filter(item => 
            item.item_type === type
        );
    }
    
    if (brand) {
        filtered = filtered.filter(item => 
            item.brand && item.brand.toLowerCase().includes(brand)
        );
    }
    
    if (location) {
        filtered = filtered.filter(item => 
            item.location && item.location.toLowerCase().includes(location)
        );
    }
    
    if (dateRange) {
        const now = new Date();
        filtered = filtered.filter(item => {
            const itemDate = new Date(item.found_date);
            const diffDays = Math.floor((now - itemDate) / (1000 * 60 * 60 * 24));
            
            switch(dateRange) {
                case 'today': return diffDays === 0;
                case 'week': return diffDays <= 7;
                case 'month': return diffDays <= 30;
                case 'year': return diffDays <= 365;
                default: return true;
            }
        });
    }
    
    displayFoundItems(filtered);
    updateSearchStats(filtered.length, allFoundItems.length);
}

function clearAllFilters() {
    document.getElementById('filterColor').value = '';
    document.getElementById('filterType').value = '';
    document.getElementById('filterBrand').value = '';
    document.getElementById('filterLocation').value = '';
    document.getElementById('filterDate').value = '';
    
    displayFoundItems(allFoundItems);
    updateSearchStats(allFoundItems.length, allFoundItems.length);
}

function updateSearchStats(shown, total) {
    const statsContainer = document.getElementById('searchStats');
    if (statsContainer) {
        if (shown === total) {
            statsContainer.innerHTML = `Showing all ${total} item${total !== 1 ? 's' : ''}`;
        } else {
            statsContainer.innerHTML = `Found ${shown} of ${total} item${total !== 1 ? 's' : ''} matching your search`;
        }
    }
}

// ========== DISPLAY FOUND ITEMS ==========
function displayFoundItems(items) {
    const container = document.getElementById('searchResults');
    
    if (!container) return;
    
    if (items.length === 0) {
        container.innerHTML = '<div class="loading">No items found matching your search. Try different keywords or check back later.</div>';
        return;
    }
    
    container.innerHTML = items.map(item => `
        <div class="item-card">
            ${item.photo_url ? `<img src="${item.photo_url}" alt="${item.title}">` : '<div style="height:200px; background:#1a1a1a; display:flex; align-items:center; justify-content:center;">No image</div>'}
            <div class="item-card-content">
                <h3>${escapeHtml(item.title)}</h3>
                <p><span class="label">Color:</span> ${escapeHtml(item.color)}</p>
                ${item.brand ? `<p><span class="label">Brand:</span> ${escapeHtml(item.brand)}</p>` : ''}
                <p><span class="label">Type:</span> ${escapeHtml(item.item_type || 'Other')}</p>
                <p><span class="label">Description:</span> ${escapeHtml(item.public_description)}</p>
                <p><span class="label">Location:</span> ${escapeHtml(item.location)}</p>
                <p><span class="label">Found:</span> ${item.found_date} at ${item.found_time}</p>
                <span class="badge badge-open">Available to Claim</span>
                <button onclick="openVerificationModal(${item.id})" class="claim-btn">Claim This Item</button>
            </div>
        </div>
    `).join('');
}

// ========== VERIFICATION MODAL - POPUP ==========
async function openVerificationModal(itemId) {
    try {
        // Fetch item details
        const itemResponse = await fetch(`/api/found-items/${itemId}`);
        const item = await itemResponse.json();
        currentClaimItem = item;
        
        // Generate verification questions based on item type
        const questions = generateVerificationQuestions(item);
        
        // Display modal with questions
        const modalBody = document.getElementById('verificationModalBody');
        modalBody.innerHTML = `
            <div class="item-summary">
                <h4>Item: ${escapeHtml(item.title)}</h4>
                <p><strong>Color:</strong> ${escapeHtml(item.color)}</p>
                <p><strong>Location found:</strong> ${escapeHtml(item.location)}</p>
                <p><strong>Date found:</strong> ${item.found_date}</p>
            </div>
            <div class="verification-questions">
                <p class="instruction">Please answer these questions to verify you are the owner. Your answers will be compared with private information provided by the finder.</p>
                <form id="verificationForm">
                    ${questions.map((q, index) => `
                        <div class="question-card">
                            <label class="question-label">Question ${index + 1}: ${escapeHtml(q.question)}</label>
                            <textarea class="answer-input" data-question="${escapeHtml(q.question)}" rows="3" placeholder="Type your answer here..." required></textarea>
                        </div>
                    `).join('')}
                    <div class="modal-buttons">
                        <button type="button" onclick="closeVerificationModal()" class="btn-secondary">Cancel</button>
                        <button type="button" onclick="submitVerification(${itemId})" class="btn-primary">Submit Claim</button>
                    </div>
                </form>
            </div>
        `;
        
        document.getElementById('verificationModal').style.display = 'flex';
        
    } catch (error) {
        console.error('Error opening verification modal:', error);
        alert('Error loading verification questions. Please try again.');
    }
}

// ========== GENERATE VERIFICATION QUESTIONS ==========
function generateVerificationQuestions(item) {
    const questions = [];
    const itemType = item.item_type;
    
    // Get private verification info
    let privateInfo = {};
    try {
        privateInfo = JSON.parse(item.verification_info || '{}');
    } catch(e) {
        privateInfo = {};
    }
    
    // Generate questions based on item type
    if (itemType === 'electronic') {
        if (privateInfo.wallpaper && privateInfo.wallpaper.trim()) {
            questions.push({
                question: `Describe the wallpaper or lock screen image on this device.`,
                expectedAnswer: privateInfo.wallpaper
            });
        }
        if (privateInfo.passcode && privateInfo.passcode.trim()) {
            questions.push({
                question: `What is the device passcode or pattern?`,
                expectedAnswer: privateInfo.passcode
            });
        }
        questions.push({
            question: `What color is this device?`,
            expectedAnswer: item.color
        });
        questions.push({
            question: `What apps or folders are on the home screen?`,
            expectedAnswer: null
        });
        questions.push({
            question: `Are there any scratches or unique marks on this device? Describe them.`,
            expectedAnswer: null
        });
    } 
    else if (itemType === 'money') {
        if (privateInfo.amount && privateInfo.amount > 0) {
            questions.push({
                question: `What is the exact amount of money in this item?`,
                expectedAnswer: privateInfo.amount.toString()
            });
        }
        if (privateInfo.currency && privateInfo.currency !== '') {
            questions.push({
                question: `What currency type is the money?`,
                expectedAnswer: privateInfo.currency
            });
        }
        questions.push({
            question: `What color is the wallet or container?`,
            expectedAnswer: item.color
        });
        questions.push({
            question: `Describe any unique features of the money (folded, crumpled, special notes, etc.)`,
            expectedAnswer: null
        });
    }
    else {
        if (privateInfo.uniqueFeature && privateInfo.uniqueFeature.trim()) {
            questions.push({
                question: `Describe the unique identifying feature of this item.`,
                expectedAnswer: privateInfo.uniqueFeature
            });
        }
        questions.push({
            question: `What color is this item?`,
            expectedAnswer: item.color
        });
        questions.push({
            question: `Are there any scratches, marks, or damages on this item? Describe them.`,
            expectedAnswer: null
        });
        questions.push({
            question: `What is inside this item (if applicable)?`,
            expectedAnswer: null
        });
    }
    
    // Add a general question
    questions.push({
        question: `Is there anything else unique about this item that only the owner would know?`,
        expectedAnswer: null
    });
    
    // Limit to 5 questions
    return questions.slice(0, 5);
}

// ========== SUBMIT VERIFICATION ==========
async function submitVerification(itemId) {
    // Collect all answers
    const answerTextareas = document.querySelectorAll('.answer-input');
    const answers = [];
    
    for (let textarea of answerTextareas) {
        const question = textarea.getAttribute('data-question');
        const answer = textarea.value.trim();
        
        if (!answer) {
            alert('Please answer all questions before submitting.');
            return;
        }
        
        answers.push({
            question: question,
            answer: answer
        });
    }
    
    // Show loading state
    const submitBtn = document.querySelector('#verificationModal .btn-primary');
    const originalText = submitBtn.innerText;
    submitBtn.innerText = 'Submitting...';
    submitBtn.disabled = true;
    
    try {
        const response = await fetch('/api/submit-claim', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                item_id: itemId,
                claimant_id: currentUser.id,
                claimant_name: currentUser.username,
                answers: answers,
                item_details: currentClaimItem
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeVerificationModal();
            showSuccessModal();
        } else {
            alert('Error submitting claim: ' + data.error);
        }
    } catch (error) {
        console.error('Error submitting claim:', error);
        alert('Error submitting claim. Please try again.');
    } finally {
        submitBtn.innerText = originalText;
        submitBtn.disabled = false;
    }
}

// ========== MODAL FUNCTIONS ==========
function closeVerificationModal() {
    document.getElementById('verificationModal').style.display = 'none';
    currentClaimItem = null;
}

function showSuccessModal() {
    document.getElementById('successModal').style.display = 'flex';
}

function closeSuccessModal() {
    document.getElementById('successModal').style.display = 'none';
    loadFoundItems(); // Refresh the list
}

// ========== HELPER FUNCTIONS ==========
function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Add Enter key support for search
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchKeyword');
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                performSearch();
            }
        });
    }
    
    // Close modal when clicking outside
    window.onclick = function(event) {
        const verificationModal = document.getElementById('verificationModal');
        const successModal = document.getElementById('successModal');
        
        if (event.target === verificationModal) {
            closeVerificationModal();
        }
        if (event.target === successModal) {
            closeSuccessModal();
        }
    };
});
