<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Lost and Found - Login</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <div class="logo">
                Secure Lost and Found
            </div>
        </nav>

        <div id="authContainer">
            <div class="form-container" style="max-width: 450px; margin: 0 auto;">
                <h2 style="margin-bottom: 20px; text-align: center;">Welcome</h2>
                
                <div class="tabs" style="justify-content: center;">
                    <button class="tab active" onclick="switchAuthTab('login')">Login</button>
                    <button class="tab" onclick="switchAuthTab('register')">Register</button>
                </div>
                
                <div id="loginForm" class="tab-content active">
                    <form onsubmit="login(event)">
                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" id="loginUsername" required placeholder="Enter username">
                        </div>
                        <div class="form-group">
                            <label>Password</label>
                            <input type="password" id="loginPassword" required placeholder="Enter password">
                        </div>
                        <button type="submit" style="width: 100%;">Login</button>
                    </form>
                    <p style="margin-top: 15px; text-align: center; font-size: 11px; color: #888888;">
                        Demo Accounts: demo / user123 | operator / operator123
                    </p>
                </div>
                
                <div id="registerForm" class="tab-content">
                    <form onsubmit="register(event)">
                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" id="regUsername" required placeholder="Choose a username">
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="regEmail" required placeholder="your@email.com">
                        </div>
                        <div class="form-group">
                            <label>Password</label>
                            <input type="password" id="regPassword" required placeholder="Choose a password">
                        </div>
                        <button type="submit" style="width: 100%;">Register</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
